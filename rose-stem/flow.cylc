#!jinja2
{% set ANTS_MODULE = "ants/developer" %}
{% set PYTHONPATH_PREPEND = "$CYLC_WORKFLOW_RUN_DIR/share/fcm_make_ants/build/lib" %}

{% set fill_n_merge_source = ['land_cover', 'invert_mask'] %}
{% set grid_source = ['grid_to_grid', 'grid_to_variable_resolution_grid', 'grid_to_n48e_namelist', 'grid_to_n48_namelist', '3d_to_3d', '3d_to_3d_with_extrapolation', 'invert_mask'] %}
{% set target_lsm_grid_sources = ['grid_to_grid', 'invert_mask'] %}


# This links a name specified on the command in rose-stem with a
# set of cylc task dependencies
{# name_graphs contains test_option-dependency key-value pairs -#}
{%- set name_graphs = {
    "install_graph" : "install_cold",
    "ancil_2anc_graph" : "install_cold => ancil_2anc<split> => rose_ana_2anc:fail? => plot_comparisons_2anc",
    "fill_n_merge_land_cover_graph" : "install_cold => ancil_create_ite_shapefile => ancil_fill_n_merge_land_cover<fill> & ancil_fill_n_merge_land_cover_latitude_weighted_kdtree => rose_ana_fill_n_merge:fail? => plot_comparisons_fill_n_merge",
    "fill_n_merge_invert_mask_graph" : "install_cold => ancil_fill_n_merge_invert_mask<fill> & ancil_fill_n_merge_invert_mask_latitude_weighted_kdtree => rose_ana_fill_n_merge:fail? => plot_comparisons_fill_n_merge",
    "general_regrid_grid_to_grid_graph" : "install_cold => ancil_general_regrid_grid_to_grid<fill,split> => rose_ana_general_regrid<fill>:fail? => plot_comparisons_general_regrid<fill>
        install_cold => ancil_general_regrid_grid_to_grid_latitude_weighted_kdtree<split> => rose_ana_general_regrid_latitude_weighted_kdtree:fail? => plot_comparisons_general_regrid_latitude_weighted_kdtree",
    "general_regrid_grid_to_variable_graph" : "install_cold => ancil_general_regrid_grid_to_variable_resolution_grid<split> => rose_ana_general_regrid:fail? => plot_comparisons_general_regrid",
    "general_regrid_grid_to_n48e_namelist_graph" : "install_cold => ancil_general_regrid_grid_to_n48e_namelist<split> => rose_ana_general_regrid:fail? => plot_comparisons_general_regrid",
    "general_regrid_grid_to_n48_namelist_graph" : "install_cold => ancil_general_regrid_grid_to_n48_namelist<split> => rose_ana_general_regrid:fail? => plot_comparisons_general_regrid",
    "general_regrid_3d_to_3d_graph" : "install_cold => ancil_general_regrid_3d_to_3d<split> => rose_ana_general_regrid:fail? => plot_comparisons_general_regrid",
    "general_regrid_3d_to_3d_with_extrapolation" : "install_cold => ancil_general_regrid_3d_to_3d_with_extrapolation<split> => rose_ana_general_regrid:fail? => plot_comparisons_general_regrid",
    "general_regrid_invert_mask_graph" : "install_cold => ancil_general_regrid_invert_mask<fill,split> => rose_ana_general_regrid<fill>:fail? => plot_comparisons_general_regrid<fill>
        install_cold => ancil_general_regrid_invert_mask_latitude_weighted_kdtree<split> => rose_ana_general_regrid_latitude_weighted_kdtree:fail? => plot_comparisons_general_regrid_latitude_weighted_kdtree",
    "general_regrid_time_constrained": "install_cold => ancil_general_regrid_with_time_constraint<fill,split> => rose_ana_general_regrid<fill>:fail? => plot_comparisons_general_regrid<fill>
        install_cold => ancil_general_regrid_with_time_constraint_latitude_weighted_kdtree<split> => rose_ana_general_regrid_latitude_weighted_kdtree:fail? => plot_comparisons_general_regrid_latitude_weighted_kdtree",
    "build_documentation_graph": "install_cold => build_docs => linkcheck",
    "unittests_graph": "install_cold => unittests",
    "black_graph": "install_cold => black",
    "flake8_graph": "install_cold => flake8",
    "isort_graph": "install_cold => isort",
}
-%}


{# automatically generate a set of all name_graphs to use in the "all" group #}
{%- set ALL_GRAPH_ITEMS = [] -%}
{%- for key, value in name_graphs.items() -%}
    {%- if ALL_GRAPH_ITEMS.append(key) -%}
    {%- endif -%}
{%- endfor -%}


# Define groups as lists of jobs and other groups
#   If you add a new group, make sure to add it to the "all" group too
#   N.B. A group can point to other groups, take care to avoid circular
#   group dependencies
{# groups contains group_option-trigger_list key-value pairs. -#}
{# If a group option is set, each group or task in the trigger list will be set. -#}
{%- set groups = {
    "all": ALL_GRAPH_ITEMS,
    "install_tasks" : ["install_graph"],
    "core" : ["ancil_2anc_graph", "fill_n_merge", "general_regrid"],
    "fill_n_merge": ["fill_n_merge_land_cover_graph", "fill_n_merge_invert_mask_graph"],
    "general_regrid": ["general_regrid_grid_to_grid_graph", "general_regrid_grid_to_variable_graph", "general_regrid_grid_to_n48e_namelist_graph", "general_regrid_grid_to_n48_namelist_graph", "general_regrid_3d_to_3d_graph", "general_regrid_3d_to_3d_with_extrapolation", "general_regrid_time_constrained", "general_regrid_invert_mask_graph"],
    "documentation": ["build_documentation_graph"],
    "unittests": ["unittests_graph", "black_graph", "flake8_graph", "isort_graph"],
}
-%}

[scheduler]
    [[events]]
        mail events =
        shutdown handlers = shutdown_log_generator.sh
[task parameters]
        split = 0, 1, 2
        fill = spiral, kdtree

[scheduling]
    [[queues]]
        [[[regrid_queue]]]
            limit = 10
            members = ANCIL_GENERAL_REGRID

    [[dependencies]]
        R1 = """
{#- Recursively add dependencies from RUN_NAMES, replacing groups with subgroups/tasks #}
{%- set name_graphs_out = [] %}
{%- set graphs_out = [] %}

{# If no group is set then the workflow will abort running and print out the available groups #}
{%- set grouplist = groups | sort | join("\n - ") -%}
{{ assert(group is defined, 'group must be defined for this workflow: use -z group=<group>. \nAvailable groups are:\n - ' + grouplist) }}
{%- set RUN_NAMES = group -%}

{# If an unknown group is requested abort launch #}
{%- for name in RUN_NAMES %}
{{ assert(name is in groups, 'Unrecognised group: ' + name + '\nAvailable groups are:\n - ' + grouplist) }}
{%- endfor %}

{%- for name in RUN_NAMES %}
    {%- set namestack = [name] %}
    {%- for stackname in namestack recursive %}
        {%- if stackname in name_graphs %}
            {%- if name_graphs_out.append(stackname) %}
            {%- endif %}
            {%- set outgraph = name_graphs[stackname] %}
            {%- if outgraph not in graphs_out %}
            {#- Add new dependency. #}
{{ outgraph }}
                {%- if graphs_out.append(outgraph) %}
                {%- endif %}
            {%- endif %}
        {%- elif stackname in groups %}
        {#- Add the group contents to the stack. #}
{{ loop(groups[stackname]) }}
        {%- else %}
        {{ raise('Unknown group', stackname) }}
        {%- endif %}
    {%- endfor %}
{%- endfor %}
     """

# {{ groups }}
#
# {{ name_graphs_out }}
#

[runtime]
    [[root]]
        script = rose task-run
        env-script = """
module load {{ ANTS_MODULE }}
export TEST_SOURCES_DIR=$ANTS_SOURCES_DIRECTORY_DEFAULT
module unload {{ ANTS_MODULE }}
        """
        platform = {{ ROSE_ORIG_HOST }}
        execution time limit = PT10M
        [[[environment]]]
            DOCSDIR = $CYLC_WORKFLOW_RUN_DIR/share/fcm_make_ants/build/docs
            ROSE_SUITE_REVISION = $(jq '.revision' ${CYLC_WORKFLOW_RUN_DIR}/log/version/vcs.json -r)
            ANTS_MODULE = {{ ANTS_MODULE }}
            PYTHONPATH_PREPEND = {{ PYTHONPATH_PREPEND }}
            # Uncomment the following line to configure the location used for temporary files.
            # ANTS_TEMPORARY_DIR = $SCRATCH
            PYTHONDONTWRITEBYTECODE=True
            ULIMIT_SETTING = unlimited
        [[[events]]]
            mail events =

    [[LARGE]]
        [[[environment]]]
            ANTS_NPROCESSES = "max"

    [[SMALL]]

    [[install_cold]]
        inherit = SMALL
        post-script = """
                      # remove any pycache files that may have transferred from the working copy
                      cd $CYLC_WORKFLOW_RUN_DIR/share/fcm_make_ants/build
                      if (( $(find . | grep -E "(/__pycache__$|\.pyc$|\.pyo$)" | wc -l ) > 0 )); then
                        find . | grep -E "(/__pycache__$|\.pyc$|\.pyo$)" | xargs rm -rf
                      fi
                      """
        [[[environment]]]
            HOST_SOURCE_ANTS_BASE={{ CYLC_WORKFLOW_SRC_DIR ~ "/.." }}

    # ##################################
    # ANTS core
    # ##################################
    [[ANTS_CORE]]

    [[ROSE_ANA]]
        inherit = ANTS_CORE, SMALL

        # Define KGO directory from environment variable
        # ANTS_KGO_DIRECTORY_DEFAULT.  This should point to the local
        # site-specific KGO directory for the head of trunk.  For an
        # individual rose stem test, this can be overridden with the
        # environment variable ANTS_KGO_DIRECTORY_OVERRIDE to point to
        # different KGOs for just that test during development.
        pre-script = '''
if [ -v ANTS_KGO_DIRECTORY_OVERRIDE ]
then
    export TEST_RESULTS_DIR=${ANTS_KGO_DIRECTORY_OVERRIDE}
else
    # It's harmless to use a `module load` here: if there's an issue with
    # loading the module, it will be identified during the ants-launch command
    # used in each rose stem test.
    module load {{ ANTS_MODULE }}
    export TEST_RESULTS_DIR=${ANTS_KGO_DIRECTORY_DEFAULT}
    module unload {{ ANTS_MODULE }}
fi
'''

    {% for source in fill_n_merge_source %}
    [[ANCIL_FILL_N_MERGE_{{ source }}]]
        inherit = ANTS_CORE, LARGE

    [[ancil_fill_n_merge_{{ source }}<fill>]]
        inherit = ANCIL_FILL_N_MERGE_{{ source }}
        script = rose task-run --app-key=ancil_fill_n_merge -O {{ source }}

    [[ancil_fill_n_merge_{{ source }}_latitude_weighted_kdtree]]
        inherit = ANCIL_FILL_N_MERGE_{{ source }}
        script = rose task-run --app-key=ancil_fill_n_merge -O {{ source }} -O latitude-weighted-kdtree
    {% endfor %}

    [[ancil_create_ite_shapefile]]
        inherit = ANTS_CORE, SMALL
        [[[environment]]]
            ROSE_TASK_APP = ancil_create_shapefile

    [[rose_ana_fill_n_merge]]
        inherit = ROSE_ANA
        [[[environment]]]
            ROSE_TASK_APP = rose_ana
            ROSE_APP_OPT_CONF_KEYS = fill_n_merge

    [[ANCIL_2ANC]]
        inherit=ANTS_CORE, LARGE

    [[ancil_2anc<split>]]
        inherit=ANCIL_2ANC
        script = rose task-run --app-key=ancil_2anc

    [[rose_ana_2anc]]
        inherit = ROSE_ANA
        [[[environment]]]
            ROSE_TASK_APP = rose_ana
            ROSE_APP_OPT_CONF_KEYS = 2anc

    # Core ants applications
    [[ANCIL_GENERAL_REGRID]]

    {% for source in grid_source %}
    [[ANCIL_GENERAL_REGRID_{{ source }}]]
        inherit=ANTS_CORE, ANCIL_GENERAL_REGRID, LARGE

    {% if source in target_lsm_grid_sources %}
    [[ancil_general_regrid_{{ source }}_latitude_weighted_kdtree<split>]]
        inherit = ANCIL_GENERAL_REGRID_{{ source }}
        script = rose task-run --app-key=ancil_general_regrid -O {{ source }} -O latitude-weighted-kdtree

    [[ancil_general_regrid_{{ source }}<fill,split>]]
    {% else %}
    [[ancil_general_regrid_{{ source }}<split>]]
    {% endif %}
        inherit = ANCIL_GENERAL_REGRID_{{ source }}
        script = rose task-run --app-key=ancil_general_regrid -O {{ source }}
    {% endfor %}

    [[ANCIL_GENERAL_REGRID_WITH_TIME_CONSTRAINT]]
        inherit=ANTS_CORE, ANCIL_GENERAL_REGRID, LARGE

    [[ancil_general_regrid_with_time_constraint<fill,split>]]
        inherit=ANCIL_GENERAL_REGRID_WITH_TIME_CONSTRAINT
        script = rose task-run --app-key=ancil_general_regrid_with_time_constraint

    [[ancil_general_regrid_with_time_constraint_latitude_weighted_kdtree<split>]]
        inherit=ANCIL_GENERAL_REGRID_WITH_TIME_CONSTRAINT
        script = rose task-run --app-key=ancil_general_regrid_with_time_constraint -O latitude-weighted-kdtree

    [[rose_ana_general_regrid]]
        inherit = ROSE_ANA
        [[[environment]]]
            ROSE_TASK_APP = rose_ana
            ROSE_APP_OPT_CONF_KEYS = general_regrid

    [[rose_ana_general_regrid<fill>]]
        inherit = ROSE_ANA
        [[[environment]]]
            ROSE_TASK_APP = rose_ana
            ROSE_APP_OPT_CONF_KEYS = general_regrid_${CYLC_TASK_PARAM_fill}

    [[rose_ana_general_regrid_latitude_weighted_kdtree]]
        inherit = ROSE_ANA
        [[[environment]]]
            ROSE_TASK_APP = rose_ana
            ROSE_APP_OPT_CONF_KEYS = general_regrid_latitude_weighted_kdtree

    # ##################################
    # Build Documentation
    # ##################################
    [[DOCUMENTATION]]
        inherit = ANTS_CORE
        # Following needed to ensure that we get the ANTS version of jinja2 rather
        # than the rose/cylc version.
        pre-script = export PYTHONPATH_PREPEND=$(module load $ANTS_MODULE; python -c "import site; print(':'.join(site.getsitepackages()))"):$PYTHONPATH_PREPEND
        script = rose task-run --command-key=$CYLC_TASK_NAME
        [[[environment]]]
            ROSE_TASK_APP = build_docs

    [[build_docs]]
        inherit = DOCUMENTATION

    [[linkcheck]]
        inherit = DOCUMENTATION

    # ##################################
    # Run unittests
    # ##################################
    [[unittests]]
        inherit = ANTS_CORE

    # ##################################
    # Run QA tests
    # ##################################
    [[black]]
        inherit = ANTS_CORE
    [[flake8]]
        inherit = ANTS_CORE
    [[isort]]
        inherit = ANTS_CORE

    # ##################################
    # Comparison plotting
    # ##################################
    [[PLOT_COMPARISONS]]
        inherit = ROSE_ANA
        [[[environment]]]
            ROSE_TASK_APP = plot_comparisons

    [[plot_comparisons_2anc]]
        inherit = PLOT_COMPARISONS
        [[[environment]]]
            TARGET_ANA_TASK_WORK_DIR=${CYLC_WORKFLOW_WORK_DIR}/${CYLC_TASK_CYCLE_POINT}/rose_ana_2anc

    [[plot_comparisons_fill_n_merge]]
        inherit = PLOT_COMPARISONS
        [[[environment]]]
            TARGET_ANA_TASK_WORK_DIR=${CYLC_WORKFLOW_WORK_DIR}/${CYLC_TASK_CYCLE_POINT}/rose_ana_fill_n_merge

    [[plot_comparisons_general_regrid_latitude_weighted_kdtree]]
        inherit = PLOT_COMPARISONS
        [[[environment]]]
            TARGET_ANA_TASK_WORK_DIR=${CYLC_WORKFLOW_WORK_DIR}/${CYLC_TASK_CYCLE_POINT}/rose_ana_general_regrid_latitude_weighted_kdtree

    [[plot_comparisons_general_regrid]]
        inherit = PLOT_COMPARISONS
        [[[environment]]]
            TARGET_ANA_TASK_WORK_DIR=${CYLC_WORKFLOW_WORK_DIR}/${CYLC_TASK_CYCLE_POINT}/rose_ana_general_regrid

    [[plot_comparisons_general_regrid<fill>]]
        inherit = PLOT_COMPARISONS
        [[[environment]]]
            TARGET_ANA_TASK_WORK_DIR=${CYLC_WORKFLOW_WORK_DIR}/${CYLC_TASK_CYCLE_POINT}/rose_ana_general_regrid_${CYLC_TASK_PARAM_fill}
